RewriteEngine On
RewriteBase /

# Remove .php extension from URLs
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# Blog posts: /blog/{slug} -> blog.php
RewriteRule ^blog/([a-zA-Z0-9\-]+)$ blog.php [L,QSA]

# Package details: /package/{slug} -> package.php
RewriteRule ^package/([a-zA-Z0-9\-&,]+)$ package.php [L,QSA]

# Static pages without .php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(about-us|contact|faq|blog|cancellation-policy|privacy-policy|terms-and-condition|sitemap)$ $1.php [L]

# Collection pages: /{slug} -> collection.php (must be LAST)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/_next/
RewriteCond %{REQUEST_URI} !^/icon/
RewriteCond %{REQUEST_URI} !^/photo/
RewriteCond %{REQUEST_URI} !^/reels/
RewriteCond %{REQUEST_URI} !^/travelxploria/
RewriteCond %{REQUEST_URI} !^/data/
RewriteCond %{REQUEST_URI} !^/includes/
RewriteRule ^([a-zA-Z0-9\-]+)$ collection.php [L,QSA]

# Default
DirectoryIndex index.php
