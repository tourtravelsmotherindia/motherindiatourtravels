  "seo": {
    "home_title": "Mother India Tour Travels | Best Travel Agency in Delhi",
    "home_description": "Discover India with Mother India Tour Travels – the best travel agency in Delhi. Affordable & customized tour packages for domestic and international destinations.",
    "og_image": "https://i.postimg.cc/CMvnKFqV/Whats-App-Image-2025-08-13-at-17-36-07-6265f9e0.jpg"
  },
  "cross_linking_rules": {
    "package → destinations": "package.destination_ids[] → destinations[id]",
    "package → states": "ALL states whose cities appear in destination_ids (multi-state packages appear in ALL their states)",
    "package → countries": "package.country_id + any international destinations",
    "package → categories": "package.category_ids[] → categories[id]",
    "destination.package_ids": "reverse: packages that visit this destination",
    "state.package_ids": "reverse: packages that visit ANY city in this state",
    "country.package_ids": "reverse: packages for this country",
    "category.package_ids": "reverse: packages tagged with this category"
  },
  "url_structure": {
    "/": "Homepage",
    "/packages": "All packages listing",
    "/packages/{slug}": "Package page with duration variants (tabs)",
    "/destinations": "All destinations listing",
    "/destinations/{slug}": "Destination page + packages to it",
    "/categories/{slug}": "Category listing page",
    "/india/{state-slug}": "State page",
    "/countries/{slug}": "Country page",
    "/blog/{slug}": "Blog post",
    "/search?q=": "Search — noindex"
  },
  "seo_principles": [
    "Duration variants (4D/5D/6D) on ONE package page → no keyword cannibalization",
    "New package URL only when destination combination changes significantly",
    "Category pages → informational keywords ('honeymoon tour packages')",
    "Destination pages → 'X tour', 'visit X' keywords",
    "Package pages → 'X tour package', 'X itinerary' keywords"
  ]
}
