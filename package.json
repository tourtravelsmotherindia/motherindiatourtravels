{
  "name": "mother-india",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "workers": "concurrently \"npm --prefix cloudflare/api-worker run dev -- --port 8787 --inspector-port 9229\" \"npm --prefix cloudflare/images-worker run dev -- --port 7878 --inspector-port 9230\"",
    "build": "npx prisma generate && npx prisma migrate deploy && next build",
    "build:static": "npx prisma generate && npx prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:reset": "npx prisma migrate reset",
    "db:seed": "npx prisma db seed"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.101.2",
    "countries-list": "^3.4.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zustand": "^5.0.14"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "^3.9.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "wrangler": "^4.110.0"
  }
}
