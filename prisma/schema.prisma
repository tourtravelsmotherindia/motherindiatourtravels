// Prisma schema for Mother India Tour Travels
// PostgreSQL database hosted on Supabase
// Modern relational schema — v2.0

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// GEOGRAPHY GROUP
// Country → State → Destination → Attraction
// ─────────────────────────────────────────────

model Country {
  id                     String  @id @default(cuid())
  name                   String
  slug                   String  @unique
  continent              String
  isDomestic             Boolean @default(false)
  isFeatured             Boolean @default(false)
  capital                String  @default("")
  currency               String  @default("")
  languages              String[] // PostgreSQL native array
  visaRequiredForIndians Boolean @default(true)
  visaOnArrival          Boolean @default(false)
  description            String  @default("")
  seoTitle               String  @default("")
  seoDescription         String  @default("")
  image                  String  @default("")
  latitude               Float?
  longitude              Float?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  states       State[]
  destinations Destination[]
  packages     Package[]

  @@index([slug])
  @@index([isFeatured])
  @@index([isDomestic])
}

model State {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  countryId   String
  capital     String  @default("")
  isFeatured  Boolean @default(false)
  description String  @default("")
  image       String  @default("")
  latitude    Float?
  longitude   Float?

  country      Country       @relation(fields: [countryId], references: [id])
  destinations Destination[]
  packages     Package[]

  @@index([countryId])
  @@index([slug])
  @@index([isFeatured])
}

enum DestinationType {
  CITY
  REGION
  BEACH
  HILL_STATION
  WILDLIFE
  PILGRIMAGE
  ISLAND
  HERITAGE
  ADVENTURE
}

model Destination {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  stateId         String?
  countryId       String
  type            DestinationType @default(CITY)
  isFeatured      Boolean         @default(false)
  description     String          @default("")
  bestTimeToVisit String          @default("")
  climate         String          @default("")
  latitude        Float?
  longitude       Float?
  image           String          @default("")
  seoTitle        String          @default("")
  seoDescription  String          @default("")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  country  Country  @relation(fields: [countryId], references: [id])
  state    State?   @relation(fields: [stateId], references: [id])

  attractions          Attraction[]
  packageDestinations  PackageDestination[]
  galleryImages        GalleryImage[]
  blogPosts            BlogPost[]

  // Self-join for nearby destinations
  asSource    DestinationNeighbour[] @relation("SourceDestination")
  asNeighbour DestinationNeighbour[] @relation("NeighbourDestination")

  @@index([countryId])
  @@index([stateId])
  @@index([slug])
  @@index([isFeatured])
}

// Self-join table for nearby destinations
model DestinationNeighbour {
  destinationId String
  neighbourId   String

  destination Destination @relation("SourceDestination", fields: [destinationId], references: [id], onDelete: Cascade)
  neighbour   Destination @relation("NeighbourDestination", fields: [neighbourId], references: [id], onDelete: Cascade)

  @@id([destinationId, neighbourId])
}

// A real entity with coordinates — replaces JSON topAttractions string
model Attraction {
  id            String  @id @default(cuid())
  name          String
  slug          String  @unique
  destinationId String
  description   String  @default("")
  image         String  @default("")
  latitude      Float?
  longitude     Float?
  sortOrder     Int     @default(0)

  destination        Destination          @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  packageAttractions PackageAttraction[]

  @@index([destinationId])
  @@index([slug])
}

// ─────────────────────────────────────────────
// PACKAGE GROUP
// ─────────────────────────────────────────────

model Category {
  id             String @id @default(cuid())
  name           String
  slug           String @unique
  description    String @default("")
  icon           String @default("")
  sortOrder      Int    @default(0)
  seoTitle       String @default("")
  seoDescription String @default("")

  packageCategories PackageCategory[]

  @@index([slug])
}

model Package {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  overview       String   @default("")
  highlights     String[] // PostgreSQL native array
  inclusions     String[]
  exclusions     String[]
  notes          String[]
  heroImage      String   @default("")
  galleryImages  String[]
  tourStyle      String   @default("Classic") // Heritage, Beach, Wildlife, Pilgrimage, Adventure
  groupSizeMax   Int      @default(12)
  groupSizeAvg   Int      @default(10)
  stayType       String   @default("Premium Hotels")
  marketingPitch String   @default("")
  isPopular      Boolean  @default(false)
  isDomestic     Boolean  @default(true)
  tags           String[]
  countryId      String
  stateId        String?
  seoTitle       String   @default("")
  seoDescription String   @default("")
  seoKeywords    String[]
  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  country Country @relation(fields: [countryId], references: [id])
  state   State?  @relation(fields: [stateId], references: [id])

  // Proper relational many-to-many (no JSON arrays)
  categories        PackageCategory[]
  variants          PackageVariant[]
  bookingInquiries  BookingInquiry[]

  @@index([slug])
  @@index([isPopular])
  @@index([isDomestic])
  @@index([countryId])
  @@index([stateId])
}

// Join table: Variant ↔ Destination (with sort order for tour route order)
model PackageDestination {
  variantId     String
  destinationId String
  sortOrder     Int    @default(0)

  variant     PackageVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  destination Destination    @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@id([variantId, destinationId])
  @@index([variantId])
  @@index([destinationId])
}

// Join table: Package ↔ Category
model PackageCategory {
  packageId  String
  categoryId String

  package  Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([packageId, categoryId])
}

// Join table: Variant ↔ Attraction (for the "Where You'll Be" map)
model PackageAttraction {
  variantId    String
  attractionId String

  variant    PackageVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attraction Attraction     @relation(fields: [attractionId], references: [id], onDelete: Cascade)

  @@id([variantId, attractionId])
}

// Variant slug is auto-generated: e.g. "3n-4d" from nights=3, days=4
model PackageVariant {
  id              String   @id @default(cuid())
  packageId       String
  slug            String   // Auto-generated: "${nights}n-${days}d"
  label           String   // Display: "3 Nights / 4 Days"
  nights          Int
  days            Int
  durationText    String   @default("") // Free-form override text
  basePrice       Float?   // INR
  discountedPrice Float?
  sortOrder       Int      @default(0)
  isDefault       Boolean  @default(false) // First/featured variant
  heroImage       String?
  galleryImages   String[]

  package          Package            @relation(fields: [packageId], references: [id], onDelete: Cascade)
  itinerary        ItineraryDay[]
  bookingInquiries BookingInquiry[]
  destinations     PackageDestination[]
  attractions      PackageAttraction[]

  @@unique([packageId, slug])
  @@index([packageId])
  @@index([slug])
}

model ItineraryDay {
  id          String   @id @default(cuid())
  variantId   String
  day         Int
  title       String
  description String
  images      String[]

  variant PackageVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
}

// ─────────────────────────────────────────────
// CONTENT GROUP
// ─────────────────────────────────────────────

enum HeroMode {
  SLIDES
  VIDEO
}

// Singleton (id = 1): controls the homepage hero
model HeroConfig {
  id       Int      @id @default(1)
  mode     HeroMode @default(SLIDES)
  videoUrl String   @default("") // Only used when mode = VIDEO
  updatedAt DateTime @updatedAt

  slides HeroSlide[]
}

model HeroSlide {
  id           String @id @default(cuid())
  heroConfigId Int    @default(1)
  image        String
  tag          String @default("")
  title        String
  description  String @default("")
  sortOrder    Int    @default(0)

  heroConfig HeroConfig @relation(fields: [heroConfigId], references: [id], onDelete: Cascade)

  @@index([heroConfigId])
}

// Generic per-section CMS text (replaces FAQTagline singleton and SiteConfig anti-pattern)
// key examples: "faq", "gallery", "why-choose-us", "testimonials"
model SiteSection {
  id       String  @id @default(cuid())
  key      String  @unique // e.g. "faq", "gallery"
  tagline  String  @default("")
  subtitle String  @default("")
  image    String? // Image URL/path for the section
  metaJson Json?   // Any additional section-specific config

  @@index([key])
}

model FAQ {
  id        String @id @default(cuid())
  question  String
  answer    String
  sortOrder Int    @default(0)

  @@index([sortOrder])
}

model GalleryImage {
  id            String  @id @default(cuid())
  title         String
  location      String  @default("")
  image         String
  altText       String  @default("")
  sortOrder     Int     @default(0)
  destinationId String?

  destination Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)

  @@index([destinationId])
  @@index([sortOrder])
}

model BlogPostCategory {
  id   String @id @default(cuid())
  name String
  slug String @unique

  posts BlogPost[]

  @@index([slug])
}

model BlogPost {
  id                 String    @id @default(cuid())
  slug               String    @unique
  title              String
  excerpt            String    @default("")
  content            String    @default("") // Markdown
  coverImage         String    @default("")
  authorName         String    @default("")
  authorImage        String    @default("")
  readingTimeMinutes Int       @default(5)
  publishedAt        DateTime?
  isPublished        Boolean   @default(false)
  isFeatured         Boolean   @default(false)
  tags               String[]
  destinationId      String?
  categoryId         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  destination Destination?      @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  category    BlogPostCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([isPublished])
  @@index([isFeatured])
  @@index([destinationId])
}

// ─────────────────────────────────────────────
// LEAD CAPTURE GROUP
// ─────────────────────────────────────────────

enum InquiryStatus {
  NEW
  READ
  CONTACTED
  CLOSED
}

enum InquirySource {
  BOOKING_FORM
  POPUP
  WHATSAPP
  PHONE
}

model BookingInquiry {
  id              String        @id @default(cuid())
  packageId       String?
  variantId       String?
  name            String
  email           String
  phone           String
  travelDate      DateTime?
  numberOfPeople  Int           @default(1)
  message         String        @default("")
  status          InquiryStatus @default(NEW)
  source          InquirySource @default(BOOKING_FORM)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  package Package?        @relation(fields: [packageId], references: [id], onDelete: SetNull)
  variant PackageVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([packageId])
  @@index([createdAt])
}

enum ContactStatus {
  NEW
  READ
  REPLIED
}

model ContactSubmission {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String        @default("")
  subject   String        @default("")
  message   String
  status    ContactStatus @default(NEW)
  createdAt DateTime      @default(now())

  @@index([status])
  @@index([createdAt])
}

model NewsletterSubscriber {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String    @default("")
  isVerified      Boolean   @default(false)
  subscribedAt    DateTime  @default(now())
  unsubscribedAt  DateTime?

  @@index([email])
  @@index([isVerified])
}

// ─────────────────────────────────────────────
// COMPANY GROUP
// ─────────────────────────────────────────────

// Singleton record (id = 1)
model Company {
  id               Int      @id @default(1)
  name             String
  tagline          String   @default("")
  website          String   @default("")
  phones           String[] // PostgreSQL native array
  email            String   @default("")
  address          String   @default("")
  whatsappNumber   String   @default("")
  timezone         String   @default("Asia/Kolkata")
  schedule         Json     // Array of working hours objects
  exceptions       Json     @default("[]")
  socialMedia      Json     // { facebook, instagram, twitter, ... }
  certifications   String[]
  about            Json     // Rich about section JSON
  googleAnalytics  String   @default("")
  googleTagManager String   @default("")
  latitude         Float?
  longitude        Float?
  updatedAt        DateTime @updatedAt
}

// Loose-string reviews (sourced from Google/TripAdvisor externally)
model Testimonial {
  id         String   @id @default(cuid())
  reviewer   String
  review     String
  rating     Int      // 1–5
  packageName String  @default("") // Loose string — not a FK
  source     String   @default("Google") // e.g. Google, TripAdvisor
  isApproved Boolean  @default(true)
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([isApproved])
  @@index([isFeatured])
}
